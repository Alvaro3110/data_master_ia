# ─── LLM Provider ────────────────────────────────────────────────────────────
# Ollama (local, gratuito) — padrão
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# OpenAI (fallback) — opcional
OPENAI_API_KEY=

# Anthropic (para Text2SQL SDK) — opcional; se vazio usa Ollama
ANTHROPIC_API_KEY=

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Jina AI — opcional; se vazio usa sentence-transformers local
JINA_API_KEY=
JINA_MODEL=jina-embeddings-v3

# ─── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH_INDEX_RULES=pricing-rules

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg2://app:app@localhost:5432/app

# ─── DuckDB (dev local) ───────────────────────────────────────────────────────
DUCKDB_PATH=./data/pricing.duckdb

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=dev-secret-key-change-in-production

# ─── Guardrail ────────────────────────────────────────────────────────────────
GUARDRAIL_THRESHOLD=60
MAX_RETRIEVAL_ATTEMPTS=2

# ─── Security ─────────────────────────────────────────────────────────────────
SQL_MAX_ROWS=1000
SQL_TIMEOUT_SECONDS=30
COST_BUDGET_ROWS=100000
